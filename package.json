{
  "name": "y-multiplex-websocket-server",
  "version": "0.2.2",
  "description": "multiplex y-websocket",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "start": "node ./src/server.js",
    "dist": "rm -rf dist && rollup -c && tsc",
    "lint": "standard && tsc",
    "test": "npm run lint && node --test --test-force-exit test",
    "preversion": "npm run lint && npm run dist && test -e dist/src/server.d.ts && test -e dist/server.cjs"
  },
  "bin": {
    "y-websocket-multiplex-server": "src/server.js",
    "y-websocket": "src/server.js"
  },
  "files": [
    "dist/*",
    "src/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./server": {
      "types": "./dist/src/server.d.ts",
      "default": "./src/server.js"
    },
    "./utils-docs": {
      "import": "./src/utils-docs.js",
      "require": "./dist/utils-docs.cjs",
      "types": "./dist/src/utils-docs.d.ts",
      "default": "./src/utils-docs.js"
    },
    "./utils-connection": {
      "import": "./src/utils-connection.js",
      "require": "./dist/utils-connection.cjs",
      "types": "./dist/src/utils-connection.d.ts",
      "default": "./src/utils-connection.js"
    },
    "./multiplex-provider": {
      "import": "./src/multiplex-provider.js",
      "require": "./dist/multiplex-provider.cjs",
      "types": "./dist/src/multiplex-provider.d.ts",
      "default": "./src/multiplex-provider.js"
    },
    "./callback": {
      "import": "./src/callback.js",
      "require": "./dist/callback.cjs",
      "types": "./dist/src/callback.d.ts",
      "default": "./src/callback.js"
    },
    "./cluster": {
      "import": "./src/cluster.js",
      "require": "./dist/cluster.cjs",
      "types": "./dist/src/cluster.d.ts",
      "default": "./src/cluster.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyrusNG/y-multiplex-websocket-server.git"
  },
  "keywords": [
    "Yjs"
  ],
  "author": "Cyrus NG <wu.cyrus@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CyrusNG/y-multiplex-websocket-server/issues"
  },
  "homepage": "https://github.com/CyrusNG/y-multiplex-websocket-server#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "standard": {
    "ignore": [
      "/dist",
      "/node_modules"
    ]
  },
  "dependencies": {
    "@y/protocols": "1.0.6-1",
    "lib0": "^0.2.102",
    "nats": "^2.29.3",
    "ws": "^6.2.1"
  },
  "peerDependencies": {
    "yjs": "^13 || ^14"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/ws": "^8.5.10",
    "rollup": "^4.39.0",
    "standard": "^17.1.2",
    "typescript": "^5.8.3",
    "yjs": "^14.0.0-7"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=16.0.0"
  }
}
